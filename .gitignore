# ── Real catalog data (keep out of source control) ────────────────────────────
# barcodes.txt is read by fetch_callnumber_labels.py; books.csv is its output.
# An example template lives at barcodes.example.txt — copy it to barcodes.txt
# locally with your real barcodes, but don't commit the result.
barcodes.txt
books.csv

# ── Build / deploy artifacts (reproducible from source) ───────────────────────
callnumber-strips-deploy/
callnumber-strips-deploy.zip

# ── Passenger restart trigger (created on the production server) ──────────────
tmp/
