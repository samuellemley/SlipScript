# Copy this file to .env and fill in your real values.
# Do NOT commit .env to git — it is listed in .gitignore.

# ── Alma API key ──────────────────────────────────────────────────────────────
# Must have Read/Write access to the Bibs API for new-barcode write-back to
# work. Generate one at https://developers.exlibrisgroup.com/ under your
# institution's sandbox or production environment.
ALMA_API_KEY=

# ── Alma cluster base URL (optional) ──────────────────────────────────────────
# Defaults to the North America cluster if unset. Other regions:
#   https://api-eu.hosted.exlibrisgroup.com   (Europe)
#   https://api-ap.hosted.exlibrisgroup.com   (Asia Pacific)
#   https://api-ca.hosted.exlibrisgroup.com   (Canada)
#   https://api-cn.hosted.exlibrisgroup.com   (China)
ALMA_BASE_URL=https://api-na.hosted.exlibrisgroup.com

# ── Flask dev server port (optional) ──────────────────────────────────────────
PORT=5050
